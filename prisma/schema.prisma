// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
//output   = "../generated/prisma"
//products  Product[]
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model Auth {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
}
model Profile {
  id           String   @id @default(uuid())
  authId       String   @unique
  auth         Auth     @relation(fields: [authId], references: [id], onDelete: Cascade)
  name         String
  username     String?  @unique
  designation  String?
  phone        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
model Category {
  id        String   @id @default(uuid()) @unique
  name      String   @unique
  slug      String   @unique
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model Product {
  id          String   @id @default(uuid())
  name        String
  slug String? @unique
  shortName String? 
  stock       Int
  description String?
  keyFeature  String?
  specification String? @default("")
  application String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  relatedProducts ProductRelation[] @relation("ParentProduct")
  childProducts   ProductRelation[] @relation("ChildProduct")
  sectionId String?
  section Section? @relation(fields: [sectionId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductImage {
  id        String   @id @default(uuid())
  url       String
  imageId   String
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
model ProductRelation{
  id        String   @id @default(uuid())
  parentId  String   
  childId   String   
  createdAt DateTime @default(now())
  parent Product @relation("ParentProduct", fields: [parentId], references: [id], onDelete: Cascade)
  child  Product @relation("ChildProduct",fields: [childId], references: [id], onDelete: Cascade)
  @@unique([parentId, childId])
}
model Section{
  id String @id @default(uuid()) @unique
  name String
  slug String @unique
  priority String
  products  Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model Query{
  id String @id @default(uuid()) @unique
  name String
  whatsappNumber String
  email String
  image String?
  productName String?
  message String
  checked Boolean @default(false)
  type String? @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model BrandInfo{
  id String @id @default(uuid()) @unique
  name String 
  logo String 
  mobile String 
  email String 
  address String 
  zip String
  country String 
  map String
  website String
  facebook String
  linkedin String
  whatsapp String
  about String 
}